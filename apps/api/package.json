{
  "name": "api",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack -p 3001",
    "build": "pnpm build:rust && next build",
    "start": "PORT=3001 node .next/standalone/apps/api/server.js",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "typecheck": "tsc --noEmit",
    "build:miden-package-metadata": "cargo install --path miden-package-metadata --locked",
    "build:miden-verifier": "cargo install --path miden-verifier --locked",
    "build:project-template": "dotenvx run -f .env.local -- sh -c 'rm -rf $PACKAGES_PATH/project-template && cp -r templates/project-template $PACKAGES_PATH/project-template && cd $PACKAGES_PATH/project-template && CARGO_TARGET_DIR=$PACKAGES_PATH/target miden build --release'",
    "build:rust": "pnpm build:miden-package-metadata && pnpm build:miden-verifier && pnpm build:project-template",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "1.71.2",
    "archiver": "8.0.0",
    "dotenv": "17.4.2",
    "drizzle-orm": "1.0.0-rc.3",
    "lodash": "4.18.1",
    "next": "16.2.9",
    "pg": "8.21.0",
    "react": "19.2.7",
    "smol-toml": "1.6.1",
    "uuid": "14.0.0"
  },
  "devDependencies": {
    "@types/archiver": "8.0.0",
    "@types/lodash": "4.17.24",
    "@types/node": "25.9.2",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.17",
    "@workspace/eslint-config": "workspace:^",
    "@workspace/typescript-config": "workspace:*",
    "drizzle-kit": "1.0.0-rc.3",
    "eslint": "9.39.4",
    "typescript": "6.0.3"
  }
}
